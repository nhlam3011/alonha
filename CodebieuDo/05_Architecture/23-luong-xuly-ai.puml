@startuml
skinparam monochrome true

title SƠ ĐỒ LUỒNG XỬ LÝ TÌM KIẾM AI & CHATBOT

start
split
  -[Tìm kiếm thông minh]->
  :Người dùng gõ đoạn hội thoại tìm nhà\nVD: "Nhà 3 tỷ quận 7";
  :NLP NER Tự động nhận diện thực thể;
  :Gọi Gemini API với JSON Schema Prompt;
  :Trích xuất ra Object: { priceMax: 3T, district: "Quận 7" };
